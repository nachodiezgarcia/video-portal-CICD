# Archivos y carpetas que Docker no debe copiar al contenedor durante el build.
# Reducen el tamano del contexto de build y evitan filtrar informacion sensible.

# Dependencias (se instalan dentro del contenedor con npm ci)
node_modules

# Salida del build local (se genera dentro del contenedor con npm run build)
dist

# Variables de entorno locales (NUNCA deben entrar en la imagen)
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# Control de versiones
.git
.gitignore

# Documentacion y archivos de configuracion del editor
README.md
.editorconfig
.vscode

# Archivos de tests
**/*.spec.ts
**/*.test.ts
